// Enhanced Learning Path Models for Day 13
model LearningPath {
  id          Int      @id @default(autoincrement())
  userId      Int
  name        String
  description String?
  skills      String[] 
  targetSkills String? // JSON array of target skills
  difficulty  String   @default("INTERMEDIATE") // BEGINNER, INTERMEDIATE, ADVANCED
  estimatedDuration Int? // in hours
  status      String   @default("in_progress") // in_progress, completed, paused
  progress    Float    @default(0) // 0-1 progress
  isActive    Boolean  @default(true)
  pathType    String   @default("PERSONALIZED") // SKILL_BASED, CAREER_BASED, PERSONALIZED
  metadata    String?  // JSON metadata for path
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  completedAt DateTime?
  
  // Relations
  user        User     @relation("UserLearningPaths", fields: [userId], references: [id], onDelete: Cascade)
  steps       LearningPathStep[]
  progressEntries    LearningPathProgress[] @relation("LearningPathProgress")
  
  @@index([userId])
  @@index([status])
  @@index([pathType])
  @@index([isActive])
  @@index([createdAt])
  @@map("learning_paths")
}

model LearningPathStep {
  id             Int      @id @default(autoincrement())
  learningPathId Int
  skill          String
  stepOrder      Int
  stepType       String   @default("CONTENT") // CONTENT, EXERCISE, ASSESSMENT, MENTOR_SESSION, PROJECT
  stepData       String?  // JSON step details
  title          String
  description    String?
  resources      String?  // JSON array of resource IDs/URLs
  prerequisites  String?  // JSON prerequisites
  estimatedTime  Int?     // Estimated time in minutes
  difficulty     String?  // BEGINNER, INTERMEDIATE, ADVANCED
  isCompleted    Boolean  @default(false)
  completedAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  // Relations
  learningPath   LearningPath @relation(fields: [learningPathId], references: [id], onDelete: Cascade)
  progress       LearningPathProgress[]
  
  @@index([learningPathId])
  @@index([stepOrder])
  @@index([stepType])
  @@index([isCompleted])
  @@index([skill])
  @@map("learning_path_steps")
}

model LearningPathProgress {
  id               Int      @id @default(autoincrement())
  userId           Int
  learningPathId   Int
  stepId           Int?
  progressType     String   // PATH_PROGRESS, STEP_PROGRESS, SKILL_MASTERY
  progressValue    Float    // Progress value (0-1)
  progressData     String?  // JSON detailed progress data
  timeSpent        Int?     // Time spent in minutes
  lastAccessedAt   DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  
  // Relations
  user             User         @relation("UserLearningProgress", fields: [userId], references: [id], onDelete: Cascade)
  learningPath     LearningPath @relation("LearningPathProgress", fields: [learningPathId], references: [id], onDelete: Cascade)
  step             LearningPathStep? @relation(fields: [stepId], references: [id], onDelete: Cascade)
  
  @@unique([userId, learningPathId, stepId])
  @@index([userId])
  @@index([learningPathId])
  @@index([progressType])
  @@index([lastAccessedAt])
  @@map("learning_path_progress")
}


  

