generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/* ================= ENUMS ================= */

enum Role {
  USER
  ADMIN
  MENTOR
}

/* ================= USER ================= */

model User {
  id                  Int      @id @default(autoincrement())
  name                String
  email               String   @unique
  password            String
  bio                 String?
  skills              String?
  profileImage        String?
  role                Role     @default(USER)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Mentorship relations
  mentorshipsAsMentor Mentorship[] @relation("MentorRelation")
  mentorshipsAsMentee Mentorship[] @relation("MenteeRelation")

  @@index([email])
}

/* ================= MENTORSHIP ================= */

model Mentorship {
  id            Int      @id @default(autoincrement())
  mentorId      Int
  menteeId      Int
  topic         String
  status        String   @default("pending") // "pending", "accepted", "rejected", "cancelled"
  preferredSlot DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  mentor User @relation("MentorRelation", fields: [mentorId], references: [id], onDelete: Cascade)
  mentee User @relation("MenteeRelation", fields: [menteeId], references: [id], onDelete: Cascade)

  @@index([mentorId])
  @@index([menteeId])
}
